---
const {
  title = "Accessibility Checker MVP",
  description = "Scan a public page for automated WCAG accessibility issues and export a stakeholder-friendly PDF report."
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://your-tool.pages.dev").toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "Accessibility Checker MVP",
      applicationCategory: "BusinessApplication",
      operatingSystem: "Web",
      description,
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD"
      }
    })} />
    <style is:global>
      :root {
        --bg: #f6f3ea;
        --paper: #fffdf8;
        --ink: #17212b;
        --muted: #5a6672;
        --brand: #1d6b57;
        --brand-dark: #114638;
        --accent: #f4b860;
        --border: #d8d0c2;
        --danger: #a13a2f;
        --shadow: 0 16px 40px rgba(23, 33, 43, 0.08);
      }

      * { box-sizing: border-box; }
      html { font-family: Georgia, "Times New Roman", serif; color: var(--ink); background: radial-gradient(circle at top, #fff7e8, var(--bg) 50%); }
      body { margin: 0; min-height: 100vh; }
      a { color: var(--brand-dark); }
      .page { width: min(1120px, calc(100% - 2rem)); margin: 0 auto; }
      header.site-header { padding: 1.2rem 0; }
      nav { display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
      nav .brand { font-size: 1.2rem; font-weight: 700; text-decoration: none; color: var(--ink); }
      nav .links { display: flex; gap: 1rem; flex-wrap: wrap; }
      nav .links a { text-decoration: none; font-size: 0.95rem; }
      .hero { display: grid; grid-template-columns: 1.2fr .8fr; gap: 2rem; padding: 2rem 0 3rem; align-items: start; }
      .hero-copy h1 { font-size: clamp(2.6rem, 5vw, 4.8rem); line-height: 0.98; margin: 0 0 1rem; letter-spacing: -0.03em; }
      .hero-copy p { font-size: 1.1rem; line-height: 1.6; color: var(--muted); margin: 0 0 1rem; }
      .card { background: var(--paper); border: 1px solid var(--border); border-radius: 24px; padding: 1.4rem; box-shadow: var(--shadow); }
      .scan-form label { display: block; font-weight: 700; margin-bottom: 0.5rem; }
      .scan-form input, .scan-form select, .scan-form button {
        width: 100%;
        border-radius: 14px;
        border: 1px solid var(--border);
        padding: 0.9rem 1rem;
        font: inherit;
      }
      .scan-form button {
        background: var(--brand);
        color: white;
        border: none;
        font-weight: 700;
        cursor: pointer;
      }
      .scan-form button:hover { background: var(--brand-dark); }
      .stack { display: grid; gap: 1rem; }
      .grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; padding: 1rem 0 3rem; }
      .grid h2, .section h2 { font-size: 1.2rem; margin: 0 0 0.5rem; }
      .muted { color: var(--muted); }
      .pill { display: inline-flex; border-radius: 999px; background: #e8f1ee; color: var(--brand-dark); padding: 0.3rem 0.8rem; font-size: 0.9rem; font-weight: 700; margin-bottom: 0.8rem; }
      .status { white-space: pre-wrap; font-family: ui-monospace, SFMono-Regular, Consolas, monospace; font-size: 0.9rem; background: #f8f4eb; border: 1px dashed var(--border); border-radius: 16px; padding: 1rem; min-height: 120px; }
      .section { padding: 0 0 3rem; }
      footer { border-top: 1px solid var(--border); padding: 1.5rem 0 3rem; color: var(--muted); }
      @media (max-width: 900px) {
        .hero, .grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <nav>
          <a class="brand" href="/">Accessibility Checker</a>
          <div class="links">
            <a href="/how-it-works">How It Works</a>
            <a href="/faq">FAQ</a>
          </div>
        </nav>
      </header>
      <slot />
      <footer>
        Automated accessibility findings for WCAG 2.2 AA. Manual review is still required for full accessibility evaluation.
      </footer>
    </div>
  </body>
 </html>
